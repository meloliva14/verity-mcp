{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.meloliva14/verity-mcp",
  "description": "Fail-closed verify-before-you-act trust gate for AI agents. Keyless, pay-per-call via x402.",
  "repository": {
    "url": "https://github.com/meloliva14/verity-mcp",
    "source": "github"
  },
  "version": "0.1.1",
  "websiteUrl": "https://veritylayer.dev",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "verity-mcp",
      "version": "0.1.1",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "VERITY_SUITE_URL", "description": "Verity suite base URL", "isRequired": false, "default": "https://verity-suite.onrender.com" },
        { "name": "VERITY_ENGINE_URL", "description": "Verity engine base URL", "isRequired": false, "default": "https://verity-bzw7.onrender.com" }
      ]
    }
  ]
}
